# ============================================================
# FORJA — Variáveis de ambiente
# Copie este arquivo para ".env.local" e preencha os valores.
# ============================================================

# --- Supabase (obrigatório) ---
# Painel do Supabase → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# --- Notificações push (opcional — só para lembretes) ---
# Gere as chaves com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Painel do Supabase → Settings → API Keys → service_role (secreta!)
# Usada SOMENTE no servidor, para o disparo dos lembretes.
SUPABASE_SERVICE_ROLE_KEY=

# Senha que protege o endpoint de disparo (invente uma string longa)
CRON_SECRET=
